      "PowerShell(cd \"F:\\\\Expo Projects\\\\Vacationist\\\\apps\\\\mobile\"; npx tsc --noEmit 2>&1 | Where-Object { $_ -notmatch 'TS6305|The file is in the program|Matched by default' } | Select-Object -First 20)",
      "PowerShell(head *)",
      "Bash(xargs grep -l *)",
      "Bash(Select-Object -First 20)",
      "Bash(not exist *)",
      "Bash(Select-Object -First 30)",
      "PowerShell(Get-Process *)",
      "PowerShell(adb devices *)",
      "mcp__plugin_supabase_supabase__list_migrations",
      "Bash(Sort-Object -Descending)",
